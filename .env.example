# OpenAI (or GitHub Models — set base URL below)
OPENAI_API_KEY=your_openai_api_key_here

# For GitHub Models (optional — comment out OPENAI_BASE_URL to use OpenAI directly)
# OPENAI_BASE_URL=https://models.inference.ai.azure.com
# OPENAI_API_KEY=your_github_pat_here

# OpenAI model to use for blueprint generation
OPENAI_MODEL=gpt-4o-mini

# Replicate API key — get one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here
